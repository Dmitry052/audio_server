# Server
WS_PORT=8080
WS_HOST=0.0.0.0

# STT
STT_URL=http://localhost:9000/transcribe

# LLM
LLM_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=llama3
LM_STUDIO_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=local-model
SUMMARY_LANGUAGE=English
SUMMARY_MAX_SENTENCES=3

# Audio
SAMPLE_RATE=16000
CHANNELS=1
BITS_PER_SAMPLE=16
MIN_AUDIO_SECONDS=5
MIN_RMS=0.003

# Queue (pg-boss)
QUEUE_DATABASE_URL=postgres://postgres:postgres@localhost:5432/audio_server
QUEUE_CONCURRENCY=2

# Debug
DEBUG_SAVE_WAV=0
DEBUG_WAV_PATH=/tmp/audio_server_debug.wav
